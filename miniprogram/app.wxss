page {
  --primary: #e94560;
  --primary-dark: #c23152;
  --bg-dark: #1a1a2e;
  --bg-card: #ffffff;
  --text-primary: #1a1a2e;
  --text-secondary: #666666;
  --text-light: #999999;
  --border: #eeeeee;
  --bg: #f5f5f5;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--bg);
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* Card */
.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* Button */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary:active {
  background: var(--primary-dark);
  opacity: 0.9;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

/* Tag */
.tag {
  display: inline-block;
  background: #f0f0f0;
  color: var(--text-secondary);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.tag.primary {
  background: var(--primary);
  color: #fff;
}

.tag.active {
  background: rgba(233, 69, 96, 0.1);
  color: var(--primary);
  border: 1rpx solid var(--primary);
}

/* Tab/Filter bar */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: #fff;
}

.filter-item.selected {
  background: var(--primary);
  color: #fff;
}

/* Empty state */
.empty {
  text-align: center;
  padding: 120rpx 40rpx;
  color: var(--text-light);
}

.empty .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* Loading */
.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--text-light);
}
