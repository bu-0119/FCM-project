.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 0;
}

.scene-bar {
  text-align: center;
  padding: 12rpx;
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.messages {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.msg-wrapper {
  margin-bottom: 24rpx;
}

.msg {
  display: flex;
}

.msg-user {
  justify-content: flex-end;
}

.msg-bot {
  justify-content: flex-start;
}

.msg-bubble {
  max-width: 78%;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.bubble-user {
  background: var(--primary);
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.bubble-bot {
  background: #fff;
  color: var(--text-primary);
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.typing-dots {
  animation: blink 1.4s infinite both;
}

@keyframes blink {
  0%, 80%, 100% { opacity: 0; }
  40% { opacity: 1; }
}

.quick-prompts {
  padding: 0 24rpx 16rpx;
}

.prompt-item {
  display: inline-block;
  padding: 14rpx 24rpx;
  margin: 8rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.prompt-item:active {
  background: var(--primary);
  color: #fff;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: env(safe-area-inset-bottom, 16rpx);
  background: #fff;
  border-top: 1rpx solid var(--border);
  gap: 16rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg);
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  padding: 0;
  text-align: center;
}

.send-btn[disabled] {
  background: #ccc;
  color: #999;
}
