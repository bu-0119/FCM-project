<view class="container">
  <!-- User info -->
  <view class="profile-header card">
    <view class="avatar">{{loggedIn && nickname ? nickname[0] : '👤'}}</view>
    <view class="profile-info">
      <view class="nickname">{{loggedIn ? (nickname || '微信用户') : '未登录'}}</view>
      <view class="profile-id" wx:if="{{loggedIn && userId}}">ID: {{userId}}</view>
    </view>
    <button class="btn-outline" wx:if="{{!loggedIn}}" bindtap="handleLogin">微信登录</button>
    <view class="logged-in-badge" wx:else>已登录</view>
  </view>

  <!-- My teams -->
  <view class="section card">
    <view class="section-header">
      <text class="section-title">我的主队</text>
      <navigator wx:if="{{loggedIn}}" url="/pages/teams/teams" class="edit-btn">编辑</navigator>
    </view>
    <view wx:if="{{!loggedIn}}">
      <view class="empty">
        <view class="icon">⚽</view>
        <view>登录后选择主队</view>
      </view>
    </view>
    <view wx:elif="{{myTeams.length === 0}}">
      <view class="empty">
        <view class="icon">⚽</view>
        <view>还没有选择主队</view>
        <navigator url="/pages/teams/teams">
          <button class="btn-primary" style="margin-top:16rpx;">去选择</button>
        </navigator>
      </view>
    </view>
    <view class="team-list" wx:else>
      <view wx:for="{{myTeams}}" wx:key="id" class="team-item">
        <text>{{item.name}}</text>
        <text class="team-en">{{item.name_en}}</text>
      </view>
    </view>
  </view>

  <!-- Notification settings -->
  <view class="section card" wx:if="{{loggedIn}}">
    <view class="section-title">通知设置</view>
    <view class="setting-row">
      <text>比赛提醒</text>
      <picker mode="selector" range="{{reminderOptions}}" bindchange="onReminderChange">
        <text>{{notifySettings.match_reminder ? notifySettings.match_reminder + '分钟前' : '关闭'}}</text>
      </picker>
    </view>
    <view class="setting-row">
      <text>每日摘要</text>
      <picker mode="selector" range="{{summaryTimeOptions}}" bindchange="onSummaryChange">
        <text>{{notifySettings.daily_summary || '关闭'}}</text>
      </picker>
    </view>
  </view>
</view>
