<view class="container">
  <view class="teams-header">
    <view class="teams-title">选择你关注的主队</view>
    <view class="teams-subtitle">最多3支 · 已选 {{selectedIds.length}} 支</view>
  </view>

  <!-- 已选预览 -->
  <view class="selected-bar" wx:if="{{selectedNames.length > 0}}">
    <view class="selected-item" wx:for="{{selectedNames}}" wx:key="id">
      <text class="selected-name">{{item.name}}</text>
      <text class="remove-btn" bindtap="toggleTeam" data-id="{{item.id}}">✕</text>
    </view>
  </view>

  <view class="league-section" wx:for="{{leagues}}" wx:key="id">
    <view class="league-title">{{item.name}} {{item.name_en}}</view>
    <view class="team-grid">
      <view
        wx:for="{{item.teams}}"
        wx:for-item="team"
        wx:key="id"
        class="team-card {{utils.isPicked(selectedIds, team.id) ? 'selected' : ''}}"
        bindtap="toggleTeam"
        data-id="{{team.id}}"
      >
        <view class="check-mark" wx:if="{{utils.isPicked(selectedIds, team.id)}}">✓</view>
        <view class="team-name">{{team.name}}</view>
        <view class="team-name-en">{{team.name_en}}</view>
      </view>
    </view>
  </view>

  <!-- 底部保存栏 -->
  <view class="save-bar" wx:if="{{selectedIds.length > 0}}">
    <view class="save-info">已选 {{selectedIds.length}}/3 支球队</view>
    <button class="btn-primary" bindtap="saveTeams">保存选择</button>
  </view>
</view>
