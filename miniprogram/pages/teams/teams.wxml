<view class="container">
  <!-- Header -->
  <view class="teams-header">
    <view class="teams-title">选择你关注的主队</view>
    <view class="teams-subtitle">最多3支 · 已选 {{selectedIds.length}} 支</view>
  </view>

  <!-- 已选预览 -->
  <view class="selected-bar" wx:if="{{selectedNames.length > 0}}">
    <image wx:for="{{selectedNames}}" wx:key="id" class="picked-crest" src="{{item.crest}}" mode="aspectFit" />
    <view class="picked-count" wx:if="{{selectedNames.length < 3}}">+{{3 - selectedNames.length}}</view>
  </view>

  <!-- 联赛 Tab -->
  <scroll-view class="league-tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{leagues}}"
      wx:key="name"
      class="league-tab {{activeLeague === item.name ? 'active' : ''}}"
      bindtap="switchLeague"
      data-league="{{item.name}}"
    >{{item.name}}</view>
  </scroll-view>

  <!-- 当前联赛的球队 -->
  <view class="team-grid">
    <view
      wx:for="{{activeTeams}}"
      wx:for-item="team"
      wx:key="id"
      class="team-card {{utils.isPicked(selectedIds, team.id) ? 'selected' : ''}}"
      bindtap="toggleTeam"
      data-id="{{team.id}}"
    >
      <view class="team-card-inner">
        <view class="check-mark" wx:if="{{utils.isPicked(selectedIds, team.id)}}">✓</view>
        <image wx:if="{{team.crest_url}}" class="team-crest" src="{{team.crest_url}}" mode="aspectFit" />
        <view wx:else class="team-crest-placeholder">⚽</view>
        <view class="team-name">{{team.name}}</view>
      </view>
    </view>
  </view>

  <!-- 保存 -->
  <view class="save-bar" wx:if="{{selectedIds.length > 0}}">
    <view class="save-info">已选 {{selectedIds.length}}/3 支球队</view>
    <button class="btn-primary" bindtap="saveTeams">保存选择</button>
  </view>
</view>
