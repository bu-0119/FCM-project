.teams-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.teams-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.teams-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 已选预览条 */
.selected-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: var(--bg-dark);
  border-radius: 16rpx;
}

.selected-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
}

.selected-name {
  font-size: 24rpx;
  color: #fff;
}

.remove-btn {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  padding: 4rpx;
}

.container {
  padding-bottom: 140rpx;
}

.league-section {
  margin-bottom: 32rpx;
}

.league-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.team-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.team-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  position: relative;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.team-card.selected {
  border-color: var(--primary);
  background: rgba(233, 69, 96, 0.05);
}

.team-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.team-name-en {
  font-size: 22rpx;
  color: var(--text-light);
}

.check-mark {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
}

.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom, 24rpx) + 20rpx);
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.save-info {
  font-size: 26rpx;
  color: var(--text-secondary);
}
