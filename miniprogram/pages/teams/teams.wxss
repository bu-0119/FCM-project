.container {
  padding-bottom: 140rpx;
}

.teams-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.teams-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.teams-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 已选预览 */
.selected-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.picked-crest {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid var(--primary);
  box-shadow: 0 2rpx 8rpx rgba(233,69,96,0.2);
}

.picked-count {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 50%;
  background: var(--bg);
  color: var(--text-light);
  font-size: 24rpx;
  text-align: center;
  border: 2rpx dashed #ccc;
}

/* 联赛 Tab */
.league-tabs {
  display: flex;
  white-space: nowrap;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.league-tab {
  display: inline-block;
  padding: 14rpx 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  border-radius: 32rpx;
  margin-right: 16rpx;
  background: #fff;
  transition: all 0.2s;
}

.league-tab.active {
  background: var(--bg-dark);
  color: #fff;
}

/* 球队网格 */
.team-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: space-between;
}

.team-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx 20rpx;
  text-align: center;
  position: relative;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.15s;
}

.team-card.selected {
  border-color: var(--primary);
  background: linear-gradient(135deg, rgba(233,69,96,0.06), rgba(233,69,96,0.02));
}

.team-card.selected::after {
  content: '✓';
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
}

.team-crest {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 12rpx;
}

.team-crest-placeholder {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0 auto 12rpx;
  font-size: 48rpx;
  background: var(--bg);
  border-radius: 50%;
}

.team-name {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
}

/* 保存栏 */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom, 24rpx) + 20rpx);
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.save-info {
  font-size: 26rpx;
  color: var(--text-secondary);
}
