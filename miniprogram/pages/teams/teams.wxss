.container {
  padding-bottom: 160rpx;
}

.teams-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.teams-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.teams-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 已选预览 */
.selected-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.picked-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 12rpx;
  margin: 4rpx 8rpx;
  background: var(--bg-dark);
  border-radius: 24rpx;
}

.picked-crest {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
}

.picked-name {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.picked-remove {
  width: 32rpx;
  height: 32rpx;
  line-height: 28rpx;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  border: 1rpx solid rgba(255,255,255,0.3);
  border-radius: 50%;
  margin-left: 4rpx;
}

/* 联赛 Tab */
.league-tabs {
  display: flex;
  white-space: nowrap;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.league-tab {
  display: inline-block;
  padding: 14rpx 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  border-radius: 32rpx;
  margin-right: 16rpx;
  background: #fff;
  transition: all 0.2s;
}

.league-tab.active {
  background: var(--bg-dark);
  color: #fff;
}

/* 球队网格 */
.team-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}

.team-card {
  width: 50%;
  box-sizing: border-box;
  padding: 8rpx;
  background: transparent;
  text-align: center;
  position: relative;
  border: none;
}

.team-card-inner {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx 20rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  position: relative;
}

.team-card.selected .team-card-inner {
  border-color: var(--primary);
  background: linear-gradient(135deg, rgba(233,69,96,0.06), rgba(233,69,96,0.02));
}

.team-card-inner .check-mark {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  text-align: center;
  font-weight: 700;
}

.team-crest {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 12rpx;
}

.team-crest-placeholder {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0 auto 12rpx;
  font-size: 48rpx;
  background: var(--bg);
  border-radius: 50%;
}

.team-name {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
}

/* 保存栏 */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom, 24rpx) + 16rpx);
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.save-info {
  font-size: 26rpx;
  color: var(--text-secondary);
}
