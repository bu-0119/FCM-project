.team-quick-bar {
  display: flex;
  gap: 12rpx;
  padding: 0 24rpx 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.team-pill {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: #fff;
  border: 1rpx solid var(--border);
}

.team-pill.selected {
  background: var(--bg-dark);
  color: #fff;
  border-color: var(--bg-dark);
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.content-type {
  font-size: 22rpx !important;
}

.content-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.content-title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.content-summary {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.content-tags {
  margin-top: 16rpx;
}

.content-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.source-link {
  color: var(--primary);
  font-size: 24rpx;
}
