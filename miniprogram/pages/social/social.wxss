.composer {
  margin-bottom: 24rpx;
}

.composer-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  padding: 0;
}

.composer-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.team-selector {
  padding: 12rpx 24rpx;
  background: var(--bg);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.composer-btn {
  padding: 12rpx 32rpx !important;
  font-size: 26rpx !important;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.post-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.post-content {
  font-size: 30rpx;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.post-images {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.post-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.post-actions {
  display: flex;
  gap: 40rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.action-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.action-item:active {
  color: var(--primary);
}
