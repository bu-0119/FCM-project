.team-hero {
  text-align: center;
  padding: 40rpx 0;
  background: linear-gradient(135deg, var(--bg-dark), #16213e);
  margin: -24rpx -24rpx 24rpx;
  border-radius: 0 0 24rpx 24rpx;
}

.team-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.team-name-en {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
